# Kidney-Genetics-DB MCP server configuration.
# All variables use the KGDB_MCP_ prefix. Values shown are the defaults.
# Copy to .env and override as needed; no auth is required (public reads only).

# KGDB REST API base URL (paths under /api/...). Compose: http://backend:8000
KGDB_MCP_API_BASE_URL=http://localhost:8000

# httpx request timeout (seconds)
KGDB_MCP_REQUEST_TIMEOUT_SECONDS=30.0

# In-process response cache TTL (seconds)
KGDB_MCP_CACHE_TTL_DEFAULT_SECONDS=300

# Bind address and port
KGDB_MCP_HOST=0.0.0.0
KGDB_MCP_PORT=8789

# Advertised MCP protocol version
KGDB_MCP_PROTOCOL_VERSION=2025-11-25

# Default payload mode: minimal | compact | standard | full
KGDB_MCP_DEFAULT_RESPONSE_MODE=compact

# Hard cap on response size (characters)
KGDB_MCP_MAX_RESPONSE_CHARS_CAP=80000

# Allowed request origins (CSV) for the origin-validation middleware
KGDB_MCP_ALLOWED_ORIGINS=https://claude.ai,https://claude.com

# Optional Redis URL for the distributed rate-limit backend (empty = in-process)
KGDB_MCP_REDIS_URL=

# Global rate-limit ceiling (requests per second)
KGDB_MCP_RATE_LIMIT_GLOBAL_RPS=10.0
