# ============================================================
# IMPORTANT: Password Safety for Docker Compose
# ============================================================
# Docker Compose interpolates $VAR and ${VAR} in .env files.
# Passwords containing $ will be silently corrupted.
#
# Safe password generation (no special characters):
#   openssl rand -hex 32
#
# If you must use $, escape as $$:
#   ADMIN_PASSWORD=MyPa$$word    (literal: MyPa$word)
#
# Or use single quotes (Docker Compose 2.24+):
#   ADMIN_PASSWORD='MyPa$word'
# ============================================================

# Database Configuration
POSTGRES_DB=kidney_genetics
POSTGRES_USER=kidney_user
POSTGRES_PASSWORD=CHANGE_ME_USE_openssl_rand_hex_32

# Backend will construct DATABASE_URL from above vars:
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@kidney_genetics_postgres:5432/${POSTGRES_DB}
DATABASE_URL=postgresql://kidney_user:CHANGE_ME_USE_openssl_rand_hex_32@kidney_genetics_postgres:5432/kidney_genetics

# Redis (used for caching, rate limiting, and background tasks)
REDIS_URL=redis://kidney_genetics_redis:6379/0

# Backend Configuration
SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32
BACKEND_CORS_ORIGINS=[]
API_V1_STR=/api/v1
PROJECT_NAME=Kidney Genetics Database
LOG_LEVEL=INFO
LOG_FORMAT=json
ALLOWED_HOSTS=localhost,kidney-genetics.yourdomain.com
