# =============================================================================
# Kidney-Genetics Database — Production Environment
# =============================================================================
# Copy to .env.production and update all CHANGE_ME values.
#
# WARNING: Avoid $ characters in passwords/secrets — Docker Compose
# interprets them as variable references. Use `openssl rand -hex 32`
# to generate safe values.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
POSTGRES_DB=kidney_genetics
POSTGRES_USER=kidney_user
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_-hex_32
POSTGRES_HOST=kidney_genetics_postgres
POSTGRES_PORT=5432

# Full connection string (must match the above vars)
DATABASE_URL=postgresql://kidney_user:CHANGE_ME@kidney_genetics_postgres:5432/kidney_genetics

# ---------------------------------------------------------------------------
# Redis (caching, rate limiting, background tasks)
# ---------------------------------------------------------------------------
REDIS_URL=redis://kidney_genetics_redis:6379/0
REDIS_RATE_LIMIT_DB=1

# ---------------------------------------------------------------------------
# Security — JWT
# ---------------------------------------------------------------------------
# REQUIRED — Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_-hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# Security — Passwords
# ---------------------------------------------------------------------------
PASSWORD_MIN_LENGTH=8
BCRYPT_ROUNDS=12

# ---------------------------------------------------------------------------
# Default Admin (created on first startup)
# ---------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@kidney-genetics.yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_-hex_32
# Set True to force-update admin password on next restart (one-time flag)
# ADMIN_FORCE_PASSWORD_RESET=False

# ---------------------------------------------------------------------------
# CORS — List your production domain(s)
# ---------------------------------------------------------------------------
BACKEND_CORS_ORIGINS=["https://kidney-genetics.yourdomain.com"]

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=prod
SITE_URL=https://kidney-genetics.yourdomain.com

# ---------------------------------------------------------------------------
# Cache
# ---------------------------------------------------------------------------
CACHE_ENABLED=True
CACHE_DEFAULT_TTL=3600
CACHE_MAX_MEMORY_SIZE=1000

# ---------------------------------------------------------------------------
# HTTP Cache
# ---------------------------------------------------------------------------
HTTP_CACHE_ENABLED=True
HTTP_CACHE_DIR=.cache/http
HTTP_CACHE_MAX_SIZE_MB=500

# ---------------------------------------------------------------------------
# STRING-DB
# ---------------------------------------------------------------------------
STRING_VERSION=12.0
STRING_DATA_DIR=./data/string/v12.0
STRING_CACHE_TTL_DAYS=30

# ---------------------------------------------------------------------------
# Background Tasks / ARQ
# ---------------------------------------------------------------------------
AUTO_UPDATE_ENABLED=True
ARQ_QUEUE_NAME=kidney_genetics_tasks
ARQ_MAX_JOBS=3
ARQ_JOB_TIMEOUT=21600
USE_ARQ_WORKER=False

# ---------------------------------------------------------------------------
# Zenodo DOI Integration (optional)
# ---------------------------------------------------------------------------
# ZENODO_API_TOKEN=your_zenodo_token_here
# ZENODO_SANDBOX=False
# ZENODO_COMMUNITY=
