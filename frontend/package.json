{
  "name": "frontend",
  "private": true,
  "version": "0.3.4",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite-ssg build",
    "preview": "vite preview",
    "generate:gene-pages": "tsx scripts/generate-gene-pages.ts",
    "build:full": "npm run build && npm run generate:gene-pages",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write \"src/**/*.{js,ts,mjs,vue,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,mjs,vue,css,md}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui"
  },
  "dependencies": {
    "@radix-icons/vue": "^1.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/vue-table": "^8.21.3",
    "@unhead/vue": "^2.1.13",
    "@upsetjs/bundle": "^1.11.0",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.15.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cytoscape": "^3.33.2",
    "cytoscape-cose-bilkent": "^4.1.0",
    "d3": "^7.9.0",
    "lucide-vue-next": "^1.0.0",
    "lz-string": "^1.5.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "vee-validate": "^4.15.1",
    "vite-ssg": "^28.3.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vue-sonner": "^2.0.9",
    "zod": "^4.3.6"
  },
  "overrides": {
    "undici": "^7.24.1",
    "beasties": "^0.4.1",
    "@vee-validate/zod": {
      "zod": "$zod"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pinia/testing": "^1.0.3",
    "@tsconfig/node22": "^22.0.5",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "beasties": "^0.4.1",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.7.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vite-plugin-compression2": "^2.5.3",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.7"
  }
